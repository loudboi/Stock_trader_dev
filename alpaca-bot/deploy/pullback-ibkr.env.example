# Copy to /etc/alpaca-bot/pullback-ibkr.env, then: chown alpaca:alpaca, chmod 600.
# For the Interactive Brokers (EUR-only) runner. See IBKR_SETUP.md.

# --- IB Gateway / TWS connection ---
IBKR_HOST=127.0.0.1
# 4002 = Gateway paper (default), 4001 = Gateway live, 7497 = TWS paper, 7496 = TWS live.
# A live port also requires passing --live in the service ExecStart.
IBKR_PORT=4002
IBKR_CLIENT_ID=17

# --- Alerts (optional; same as the Alpaca runner) ---
ALERT_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
