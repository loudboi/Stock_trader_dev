# Copy to /etc/alpaca-bot/pullback.env, then: chown alpaca:alpaca, chmod 600.
# systemd reads this as the service's environment (plain KEY=value, no quotes,
# no shell expansion).

# --- Alpaca (required) ---
ALPACA_API_KEY=your_key_here
ALPACA_SECRET_KEY=your_secret_here
# Paper while you watch it; the live URL trades real money and also needs --live.
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --- Alerts (optional; leave blank to run silently) ---
# Slack-compatible incoming webhook (receives {"text": "..."}).
ALERT_WEBHOOK_URL=
# ...or Telegram (set BOTH):
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
